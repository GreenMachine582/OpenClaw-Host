# integrations/discord/.env.example
# Copy to .env and fill in values — never commit .env

# Bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=your_bot_token_here

# ID of the server (guild) — enables instant slash command sync (recommended)
DISCORD_GUILD_ID=your_server_id_here

# ID of the channel OpenClaw posts to and listens in
DISCORD_CHANNEL_ID=your_channel_id_here

# IDs allowed to trigger tasks (comma-separated Discord user IDs)
# Leave empty to allow all members in the channel
DISCORD_ALLOWED_USERS=
