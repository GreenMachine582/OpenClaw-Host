# integrations/github/.env.example
# Copy to .env and fill in values — never commit .env

# Personal access token — repo scope only
GITHUB_TOKEN=your_token_here

# The account or org that owns the repos this agent operates on
GITHUB_OWNER=your_org_or_username

# Default base branch for PRs
GITHUB_DEFAULT_BRANCH=main

# Comma-separated GitHub usernames to auto-request review on every PR (optional)
# GITHUB_PR_REVIEWERS=alice,bob
